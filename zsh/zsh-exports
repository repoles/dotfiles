export HISTFILE="${ZDOTDIR:-$HOME}/.zhistory" # History filepath
export HISTSIZE=50000                         # Maximum events for internal history
export SAVEHIST=10000                         # Maximum events in history file

export EDITOR="vim"
export VISUAL="vim"

export LANG=en_US.UTF-8

MYSQL_DIR="$HOMEBREW_PREFIX/opt/mysql@5.7/bin"
PYTHON_DIR="$HOMEBREW_PREFIX/opt/python/libexec/bin"

export path=($path $HOME/Scripts $MYSQL_DIR $PYTHON_DIR)
unset MYSQL_DIR PYTHON_DIR

# Usa openssl 1.1 para compilar o Ruby instalado pelo rbenv
# https://github.com/rbenv/ruby-build/wiki#suggested-build-environment
# Sem essa configuração, o openssl será baixado em cada instalação do Ruby
export RUBY_CONFIGURE_OPTS="--with-openssl-dir=$HOMEBREW_PREFIX/opt/openssl@1.1"

# Para que ao excluir usando OPTION + DELETE a
# exclusão pare em caracteres como -, _, ., etc.
export WORDCHARS=""
