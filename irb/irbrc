IRB.conf[:USE_AUTOCOMPLETE] = false
IRB.conf[:SAVE_HISTORY] ||= 1000

if defined?(::Rails)
  # Salva o histórico do IRB no diretório do projeto Rails
  # Referência: https://gist.github.com/gucki/6523172
  IRB.conf[:HISTORY_FILE] ||= File.join(ENV["PWD"], ".irb_history")
else
  IRB.conf[:HISTORY_FILE] ||= File.join(ENV["XDG_DATA_HOME"], "irb_history")
end
