{
  "autosave": "on_window_change",
  // "ui_font_family": "MonoLisaText",
  "buffer_font_family": "MonoLisaCode",
  "buffer_font_fallbacks": ["Symbols Nerd Font Mono"],
  "buffer_font_size": 16,
  "buffer_font_features": {
    "ss11": true,
    "ss13": true,
    "cv04": true,
    "cv05": true,
    "cv08": true,
    "cv09": true,
    "cv11": true,
  },
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "file_types": {
    "Shell Script": ["conf"],
  },
}
