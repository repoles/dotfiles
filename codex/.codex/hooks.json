{
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "$XDG_CONFIG_HOME/tmux/scripts/agent-tmux-status.sh waiting",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "$XDG_CONFIG_HOME/tmux/scripts/agent-tmux-status.sh busy",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "$XDG_CONFIG_HOME/tmux/scripts/agent-tmux-status.sh busy",
            "type": "command"
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$XDG_CONFIG_HOME/tmux/scripts/agent-tmux-status.sh idle",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "$XDG_CONFIG_HOME/tmux/scripts/agent-tmux-status.sh busy",
            "type": "command"
          }
        ]
      }
    ]
  }
}
