font-family = MonoLisaCode
font-family = Symbols Nerd Font Mono

font-size = 18
font-thicken = false
font-feature = +ss11, +ss13, +cv04, +cv05, +cv08, +cv09, +cv11

theme = Ayu
# theme = Argonaut
# theme = Dracula
# theme = GitHub Dark
# theme = Monokai Classic
# theme = Gruvbox Dark Hard

# background = #000000
# background-opacity = 0
# background-blur = macos-glass-regular

# cursor-style = block
# cursor-color = #666666
# cursor-text = #ffffff
# cursor-style-blink = false
# cursor-invert-fg-bg = true
adjust-cursor-thickness = 4

# custom-shader = shaders/cursor_warp.glsl

# split-divider-color = green
# unfocused-split-opacity = 1
# unfocused-split-fill = #000000

# window-decoration = none
# macos-window-shadow = false
macos-option-as-alt = true
# macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden

# window-title-font-family = JetBrains Mono

window-width = 100
window-height = 30

window-padding-x = 1
window-padding-y = 0
window-padding-balance = true
# window-padding-color = extend

# macos-icon = xray

# macos-icon = custom-style
# macos-icon-frame = aluminum
# macos-icon-ghost-color = ffffff
# macos-icon-screen-color = 000000

bell-features = no-title

notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
notify-on-command-finish-after = 5m

keybind = shift+enter=text:\x1b\r

# Cmd + Left Arrow -> Shift+Home (first non-blank char in nvim)
keybind = cmd+left=csi:1;2H

# Cmd + Right Arrow -> Shift+End (end of line in nvim)
keybind = cmd+right=csi:1;2F

